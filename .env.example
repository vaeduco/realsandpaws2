# RealAndPaws — environment variables (set these in Vercel → Project → Settings → Environment Variables).
# Copy to ".env" for local "vercel dev". NEVER commit real values.

# Supabase REST endpoint, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Supabase SERVICE ROLE key (Project → Settings → API → service_role).
# Server-side only — it bypasses Row Level Security. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Admin login credentials for /admin
ADMIN_USER=
ADMIN_PASSWORD=

# Secret used to sign the admin session cookie. Generate a random one, e.g.:
#   openssl rand -hex 32
ADMIN_SECRET=
